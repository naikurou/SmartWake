# SmartWake — Apache Configuration
# Sécurité, réécriture d'URL et protection des fichiers sensibles

Options -Indexes -MultiViews
ServerSignature Off

# ============================================================
# Réécriture d'URL (URL propres)
# ============================================================
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /smartwake/

    # Bloquer l'accès aux fichiers cachés (.env, .git, etc.)
    RewriteRule ^\.                - [F,L]

    # Ne pas réécrire les fichiers/dossiers existants
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
</IfModule>

# ============================================================
# Protection des dossiers sensibles
# ============================================================

# Bloquer l'accès direct aux includes
<FilesMatch "^(db|auth|functions)\.php$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# Bloquer l'accès aux fichiers de log et configuration
<FilesMatch "\.(log|sql|env|ini|bak|sh)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# ============================================================
# En-têtes de sécurité HTTP
# ============================================================
<IfModule mod_headers.c>
    # Protection contre le clickjacking
    Header always set X-Frame-Options "DENY"

    # Protection XSS (navigateurs anciens)
    Header always set X-XSS-Protection "1; mode=block"

    # Empêcher le MIME sniffing
    Header always set X-Content-Type-Options "nosniff"

    # Politique de référence
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Content Security Policy (CSP)
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' https://fonts.googleapis.com https://cdn.jsdelivr.net 'unsafe-inline'; style-src 'self' https://fonts.googleapis.com 'unsafe-inline'; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self'; frame-ancestors 'none';"

    # HSTS (à activer uniquement en production HTTPS)
    # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"

    # Désactiver la mise en cache des pages sensibles
    <FilesMatch "\.(php)$">
        Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
        Header set Pragma "no-cache"
    </FilesMatch>

    # Cache des assets statiques (CSS, JS, images)
    <FilesMatch "\.(css|js|png|jpg|jpeg|gif|svg|woff2|ico)$">
        Header set Cache-Control "public, max-age=86400"
    </FilesMatch>
</IfModule>

# ============================================================
# Compression Gzip (éco-conception)
# ============================================================
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/javascript
    AddOutputFilterByType DEFLATE application/javascript application/json
    AddOutputFilterByType DEFLATE text/plain text/xml
</IfModule>

# ============================================================
# PHP : configuration de sécurité
# ============================================================
<IfModule mod_php.c>
    php_flag display_errors Off
    php_flag log_errors On
    php_value error_log logs/php_errors.log
    php_flag session.cookie_httponly On
    php_flag session.cookie_secure Off
    php_value session.cookie_samesite Strict
    php_flag session.use_strict_mode On
</IfModule>
